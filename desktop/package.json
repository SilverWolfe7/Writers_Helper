{
  "name": "writers-helper-desktop",
  "version": "1.0.0",
  "description": "Writer's Helper — native desktop app",
  "homepage": "https://voice-notes-writer-1.preview.emergentagent.com/",
  "main": "main.js",
  "private": true,
  "author": {
    "name": "L J Naeyaert",
    "email": "support@writers-helper.app"
  },
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_IS_DEV=1 electron .",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux",
    "package:mas": "electron-builder --mac mas",
    "package:mas-dev": "electron-builder --mac mas-dev",
    "release:mac": "electron-builder --mac --publish always",
    "release:win": "electron-builder --win --publish always",
    "release:linux": "electron-builder --linux --publish always",
    "release:mas": "electron-builder --mac mas --publish never"
  },
  "build": {
    "appId": "app.writershelper.desktop",
    "productName": "Writer's Helper",
    "copyright": "Copyright © 2026 L J Naeyaert",
    "directories": {
      "output": "dist",
      "buildResources": "build-assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "renderer/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Writer's Helper uses your microphone to transcribe your dictation into notes.",
        "NSSpeechRecognitionUsageDescription": "Writer's Helper transcribes your voice on-device to capture your story ideas as notes."
      }
    },
    "mas": {
      "category": "public.app-category.productivity",
      "type": "distribution",
      "hardenedRuntime": false,
      "entitlements": "build-assets/entitlements.mas.plist",
      "entitlementsInherit": "build-assets/entitlements.mas.inherit.plist",
      "entitlementsLoginHelper": "build-assets/entitlements.mas.loginhelper.plist",
      "provisioningProfile": "build-assets/embedded.provisionprofile",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Writer's Helper uses your microphone to transcribe your dictation into notes.",
        "NSSpeechRecognitionUsageDescription": "Writer's Helper transcribes your voice on-device to capture your story ideas as notes.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "masDev": {
      "type": "development",
      "provisioningProfile": "build-assets/development.provisionprofile",
      "entitlements": "build-assets/entitlements.mas.plist",
      "entitlementsInherit": "build-assets/entitlements.mas.inherit.plist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "maintainer": "Writer's Helper <support@writers-helper.app>"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "SilverWolfe7",
        "repo": "Writers_Helper",
        "releaseType": "release"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^26.0.12"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}

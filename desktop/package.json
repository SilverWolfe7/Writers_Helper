{
  "name": "writers-helper-desktop",
  "version": "1.0.0",
  "description": "Writer's Helper — native desktop app",
  "homepage": "https://voice-notes-writer-1.preview.emergentagent.com/",
  "main": "main.js",
  "private": true,
  "author": {
    "name": "Writer's Helper",
    "email": "support@writers-helper.app"
  },
  "scripts": {
    "start": "electron .",
    "dev": "ELECTRON_IS_DEV=1 electron .",
    "package": "electron-builder",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "app.writershelper.desktop",
    "productName": "Writer's Helper",
    "copyright": "Copyright © 2026 Writer's Helper",
    "directories": {
      "output": "dist",
      "buildResources": "build-assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json",
      "renderer/**"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "extendInfo": {
        "NSMicrophoneUsageDescription": "Writer's Helper uses your microphone to transcribe your dictation into notes.",
        "NSSpeechRecognitionUsageDescription": "Writer's Helper transcribes your voice on-device to capture your story ideas as notes."
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Office",
      "maintainer": "Writer's Helper <support@writers-helper.app>"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://updates.writers-helper.app/desktop/${os}/${arch}/"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
